# Do not commit real keys.

# Codex binary. Defaults to the Codex.app install path.
CODEX_BIN=/Applications/Codex.app/Contents/Resources/codex

# Official OpenAI realtime, or OpenAI transcription mode.
OPENAI_API_KEY=replace-with-openai-api-key

# OpenAI Realtime bridge mode. Codex still uses normal Codex auth; this key is
# only for the bridge's voice session.
LOCAL_REALTIME_OPENAI_REALTIME_MODEL=gpt-realtime-mini
LOCAL_REALTIME_OPENAI_REALTIME_VOICE=marin
LOCAL_REALTIME_OPENAI_REALTIME_TRANSCRIBE=0

# Groq transcription mode.
GROQ_API_KEY=replace-with-groq-api-key

# Gemini Live mode.
GEMINI_API_KEY=replace-with-gemini-api-key
LOCAL_REALTIME_GEMINI_MODEL=gemini-3.1-flash-live-preview
LOCAL_REALTIME_GEMINI_VOICE=Aoede
LOCAL_REALTIME_GEMINI_CONTEXT_SYNC=0
LOCAL_REALTIME_GEMINI_SESSION_CONTEXT=1
LOCAL_REALTIME_GEMINI_SESSION_CONTEXT_MAX_CHARS=7000
LOCAL_REALTIME_GEMINI_ALLOW_BARGE_IN=1
LOCAL_REALTIME_GEMINI_BARGE_IN_MODE=transcript
LOCAL_REALTIME_GEMINI_BARGE_IN_RMS=4200
LOCAL_REALTIME_GEMINI_STRONG_BARGE_IN_RMS=8500
LOCAL_REALTIME_GEMINI_BARGE_IN_FRAMES=6
LOCAL_REALTIME_GEMINI_BARGE_IN_MIN_MS=1500
LOCAL_REALTIME_GEMINI_INPUT_GAIN=1
LOCAL_REALTIME_HANDOFF_ACK=1
LOCAL_REALTIME_HANDOFF_ACK_SPEAK=0
LOCAL_REALTIME_BACKEND_SPEECH_MAX_CHARS=0

# Shared local bridge settings.
LOCAL_REALTIME_PORT=8787
LOCAL_REALTIME_TRANSCRIPT_MODE=handoff-only

# Kokoro local TTS.
LOCAL_REALTIME_KOKORO_VOICE=af_heart
LOCAL_REALTIME_KOKORO_DTYPE=q4

# Local Whisper.
LOCAL_REALTIME_LOCAL_STT_MODEL=Xenova/whisper-medium.en
LOCAL_REALTIME_LOCAL_STT_DTYPE=q8
